PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/qa_app

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=30d

# Google Sign-In (Firebase Console → Authentication → Google → Web Client ID)
GOOGLE_CLIENT_ID=your_web_client_id.apps.googleusercontent.com

# Firebase Admin SDK (push notifications)
# Option A: file at backend/ (add filename to .gitignore!)
# Option B: for deployment — paste JSON as single line:
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
